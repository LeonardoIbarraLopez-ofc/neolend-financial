{
  "name": "neolend-financial",
  "version": "0.1.0",
  "private": true,
  "description": "NeoLend Financial Corp. — Plataforma FinTech de Crédito Digital (6 microservicios, local-first)",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "lint": "eslint \"{libs,services,clients}/**/*.ts\"",
    "format": "prettier --write \"{libs,services,clients}/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"{libs,services,clients}/**/*.{ts,tsx,json,md}\"",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "up": "docker compose up -d",
    "down": "docker compose down",
    "logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.0"
  }
}
