{
  "name": "@neolend/gateway-origination-svc",
  "version": "0.1.0",
  "private": true,
  "description": "Servicio 1 — Gateway de borde + Identidad/KYC + Saga de originación (inciso I).",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn src/main.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest --passWithNoTests --forceExit",
    "test:watch": "jest --watch --forceExit",
    "test:cov": "jest --coverage --forceExit"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@neolend/ts-common": "workspace:*",
    "@neolend/ts-events": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testMatch": ["**/*.spec.ts"],
    "transform": {
      "^.+\\.ts$": ["ts-jest", {
        "tsconfig": "<rootDir>/tsconfig.json"
      }]
    },
    "transformIgnorePatterns": ["/node_modules/", "\\.js$"],
    "collectCoverageFrom": ["src/**/*.ts"],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "@neolend/ts-common": "<rootDir>/../../libs/ts-common/src",
      "@neolend/ts-events": "<rootDir>/../../libs/ts-events/src"
    }
  }
}
