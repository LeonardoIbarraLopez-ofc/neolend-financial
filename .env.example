# ============================================================
#  NeoLend Financial — Variables de entorno LOCALES (ejemplo)
#  Copiar a .env y ajustar. NUNCA poner secretos reales aquí.
# ============================================================

# ---- Infra local (docker-compose) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=neolend
POSTGRES_PASSWORD=neolend_local_pw
REDIS_URL=redis://redis:6379
KAFKA_BROKERS=redpanda:9092

# ---- Auth (JWT local — clave de desarrollo, NO usar en prod) ----
JWT_SECRET=dev-only-change-me-super-secret
JWT_EXPIRES_IN=1h

# ---- Cifrado AES-256 de PII (clave de 32 bytes en hex para desarrollo) ----
AES_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
PII_HMAC_SALT=dev-hmac-salt-change-me

# ---- Puertos de servicios (host) ----
GATEWAY_PORT=8080
GATEWAY_ORIGINATION_PORT=8101
SCORING_PORT=8102
CREDIT_PORT=8103
SERVICING_PORT=8104
INVESTOR_PORT=8105
COMPLIANCE_PORT=8106

# ---- URLs internas entre servicios (red docker-compose) ----
SCORING_URL=http://scoring-svc:8102
CREDIT_URL=http://credit-svc:8103
SERVICING_URL=http://servicing-svc:8104
INVESTOR_URL=http://investor-svc:8105
COMPLIANCE_URL=http://compliance-svc:8106

# ---- Mocks locales ----
BUREAU_SOAP_MOCK_URL=http://bureau-soap-mock:9101
WALLET_MOCK_URL=http://wallet-mock:9102
WHATSAPP_MOCK_URL=http://whatsapp-mock:9103

# ---- Circuit breaker buró (scoring-svc) ----
BUREAU_RATE_LIMIT_RPS=8
BUREAU_TIMEOUT_MS=12000
BUREAU_CACHE_TTL_SECONDS=86400

# ---- Firma digital (compliance-svc) — claves locales ----
SIGNING_PRIVATE_KEY_PATH=/keys/signing-priv.pem
SIGNING_PUBLIC_KEY_PATH=/keys/signing-pub.pem
